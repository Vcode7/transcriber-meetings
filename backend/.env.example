# ============================================================
# AI Meeting Transcriber — Backend Configuration
# Copy this file to .env and fill in any required values.
# ============================================================

# SQLite database — stored in runtime/data/ in production
DATABASE_URL=sqlite+aiosqlite:///./voicesum.db

# JWT — change this to a long random string in production!
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=15

# ── Qwen3 4B Model (offline AI engine) ──────────────────────
# In PRODUCTION: the model is loaded from runtime/nlp-engine/
#   automatically — no HuggingFace download required.
# In DEVELOPMENT: set QWEN_MODEL_ID to download from HuggingFace Hub.
QWEN_MODEL_ID=Qwen/Qwen3-4B
QWEN_LOAD_IN_4BIT=true

# HuggingFace token — only needed for development downloads
# or pyannote diarization models. Leave blank in production.
# HF_TOKEN=your_huggingface_token_here

# ── Offline mode ─────────────────────────────────────────────
# Set to true in production to prevent any internet access.
# The app works fully offline once models are placed in runtime/.
OFFLINE_MODE=true

# ── Audio storage ────────────────────────────────────────────
# In production this resolves to: {install_dir}/runtime/uploads/
# Leave as default — config.py resolves paths automatically.
UPLOAD_DIR=uploads

# ── Models directory ─────────────────────────────────────────
# Encrypted .dat models location. Leave as default in production.
# config.py resolves this to: {install_dir}/runtime/models/
# MODELS_DIR=runtime/models

# ── Speaker identification ───────────────────────────────────
SPEAKER_SIMILARITY_THRESHOLD=0.65
MIN_SEGMENT_DURATION=1.5

# ── Transcription ────────────────────────────────────────────
WHISPER_MODEL_SIZE=medium
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=int8

# ── Word confidence thresholds ───────────────────────────────
WORD_CONF_LOW=0.7
WORD_CONF_MID=0.85

# ── Overlap detection (optional) ─────────────────────────────
OVERLAP_MODEL_PATH=checkpoints/overlap_model.pth
